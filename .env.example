# Local dev & Vercel production — use Neon PostgreSQL (SQLite file DB does not work on Vercel).
# Create a free project at https://neon.tech and copy both connection strings from the dashboard.

# Pooled connection (Neon: "Pooled connection" — host contains `-pooler`)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection (Neon: "Direct connection" — for prisma migrate deploy)
# If you only have one URL during setup, paste the direct URL here and in DATABASE_URL too.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# --- Google OAuth (NextAuth) — optional for prototype build; required for "Lanjutkan dengan Google" ---
# Generate secret: openssl rand -base64 32  (or: npx auth secret)
NEXTAUTH_SECRET="replace-with-random-32-byte-secret"
# Also accepted by Auth.js v5:
# AUTH_SECRET="same-as-nextauth-secret"

# Public site URL (no trailing slash). Local: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# --- Email (Resend) — transaksional: aplikasi mentor, reset password, dll. ---
# API key dari https://resend.com/api-keys
RESEND_API_KEY="re_xxxx"
# Pengirim terverifikasi di Resend (prod: noreply@bursa.id; dev: onboarding@resend.dev)
EMAIL_FROM="Bursa <onboarding@resend.dev>"
# Penerima notifikasi aplikasi mentor (default: admin.kitty033@passinbox.com)
MENTOR_APPLICATION_ADMIN_EMAIL="admin.kitty033@passinbox.com"
# Set false untuk menonaktifkan email aplikasi mentor tanpa menghapus API key
MENTOR_APPLICATION_EMAIL_ENABLED=true

# --- Komunitas / chat (disabled by default � heavy on bandwidth + DB) ---
# Set to true to re-enable /komunitas, chat APIs, admin chat-rooms, mentor chat.
# See Website/_archive/komunitas/RESTORE-PROMPT.md for full restore steps.
NEXT_PUBLIC_KOMUNITAS_ENABLED=false
