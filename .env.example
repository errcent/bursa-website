# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth (NextAuth + Google OAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Bursa <onboarding@resend.dev>"
MENTOR_APPLICATION_ADMIN_EMAIL=""
MENTOR_APPLICATION_EMAIL_ENABLED="true"
WAITLIST_EMAIL_ENABLED="true"

# Cloudflare Turnstile (anti-spam waitlist) — optional in dev
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# PostHog analytics — optional; loads only after cookie consent
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
