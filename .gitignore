# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local video uploads
/public/uploads/videos/*
!/public/uploads/videos/.gitkeep

# local avatar uploads
/public/uploads/avatars/*
!/public/uploads/avatars/.gitkeep

# local sqlite / prisma artifacts
/prisma/*.db
/prisma/*.db-journal

# local scratch / tooling output
.video-frames/
_check_out.txt
_tsc_exit.txt
_tsc_filtered.txt
