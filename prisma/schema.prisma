/// Public mentor onboarding form — persists across serverless cold starts.
model MentorApplication {
  id                      String                  @id @default(cuid())
  fullName                String
  email                   String
  phone                   String
  professionalTitle       String
  instruments             Json
  yearsExperience         Int
  licenseLabel            String?
  bio                     String                  @db.Text
  philosophy              String                  @db.Text
  portfolioUrl            String?
  hasExistingContent      Boolean                 @default(false)
  estimatedCoursePrice    Int?
  agreedToTerms           Boolean
  cvDocumentUrl           String?
  cvDocumentName          String?
  certificateDocumentUrl  String?
  certificateDocumentName String?
  status                  MentorApplicationStatus @default(PENDING)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model PublicDocument {
  id              String         @id @default(cuid())
  slug            String
  portal          DocumentPortal
  title           String
  eyebrow         String
  description     String
  markdownBody    String         @db.Text
  status          DocumentStatus @default(DRAFT)
  version         Int            @default(1)
  publishedAt     DateTime?
  sourceVaultPath String?
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([portal, slug])
  @@index([portal, status])
}

model DataSubjectRequest {
  id          String                   @id @default(cuid())
  fullName    String
  email       String
  requestType DataSubjectRequestType
  details     String                   @db.Text
  status      DataSubjectRequestStatus @default(PENDING)
  adminNotes  String?                  @db.Text
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

/// Public waitlist sign-ups — pre-launch email capture (UU PDP consent required).
model WaitlistEntry {
  id                    String    @id @default(cuid())
  email                 String    @unique
  consentGiven          Boolean   @default(true)
  source                String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmContent            String?
  /// SHA-256 prefix of client IP for abuse detection — not raw PII.
  ipHash                String?
  /// Legacy double opt-in timestamp — new sign-ups are confirmed immediately via consent.
  emailVerifiedAt       DateTime?
  verificationTokenHash String?   @unique
  verificationExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([createdAt])
  @@index([emailVerifiedAt])
}

/// NO-REFUND remediation flow for post-purchase dissatisfaction (founder override, QC-20260719-33).
/// Replaces the rejected refund-window recommendation. Mentors are obligated to fix/improve
/// content; platform may issue non-cash credit toward ANOTHER course or replacement access.
/// There is NO money-back path anywhere in this model.
model CourseDispute {
  id                   String                @id @default(cuid())
  userId               String
  courseId             String
  /// Optional link to the purchase this dispute concerns (never used to reverse the charge).
  transactionId        String?
  category             CourseDisputeCategory
  description          String                @db.Text
  status               CourseDisputeStatus   @default(OPEN)
  /// Mentor's remediation commitment / response.
  mentorResponse       String?               @db.Text
  resolutionNote       String?               @db.Text
  /// Non-cash platform credit granted toward ANOTHER course (Rupiah). NEVER a refund.
  platformCreditIssued Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  course               Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([status, createdAt])
  @@index([courseId, status])
}
