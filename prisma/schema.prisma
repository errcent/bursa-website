generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                             String                    @id @default(cuid())
  email                          String                    @unique
  passwordHash                   String
  nama                           String
  /// Optional short bio for the base user profile (learners, mentors, staff).
  bio                            String?
  /// Public avatar path/URL for the base user profile (e.g. /uploads/avatars/...).
  avatarUrl                      String?
  role                           UserRole                  @default(LEARNER)
  kycStatus                      KycStatus                 @default(NOT_REQUIRED)
  createdAt                      DateTime                  @default(now())
  /// Login handle — lowercase alphanumeric + underscore; separate from display name.
  username                       String?                   @unique
  /// E.164 or Indonesian +62... format.
  phone                          String?                   @unique
  /// Set once the email is verified (magic link / OTP). Gate for public/ranking metrics (QC-20260719-26).
  emailVerifiedAt                DateTime?
  /// Set once the phone is verified. Second identity anchor for Sybil resistance (QC-20260719-26).
  phoneVerifiedAt                DateTime?
  /// Non-cash platform credit (Rupiah) usable toward ANOTHER course. NEVER a refund (QC-20260719-33).
  platformCreditBalance          Int                       @default(0)
  /// Reporter reputation counters for weighted moderation (QC-20260719-40).
  moderationReportsUpheld        Int                       @default(0)
  moderationReportsDismissed     Int                       @default(0)
  adminAuditLogs                 AdminAuditLog[]
  AiConversation                 AiConversation[]
  AiUsageLog                     AiUsageLog[]
  chatAuditLogs                  ChatAuditLog[]
  chatBranchChangeRequests       ChatBranchChangeRequest[] @relation("ChatBranchChangeMentor")
  chatBranchChangeRequestReviews ChatBranchChangeRequest[] @relation("ChatBranchChangeReviewer")
  chatMessages                   ChatMessage[]
  chatMessageReactions           ChatMessageReaction[]
  chatRoomMembers                ChatRoomMember[]
  moderationReports              ContentModerationQueue[]  @relation("ReportedBy")
  moderationReviews              ContentModerationQueue[]  @relation("ReviewedBy")
  changeRequests                 CourseChangeRequest[]     @relation("ChangeRequestMentor")
  changeRequestReviews           CourseChangeRequest[]     @relation("ChangeRequestReviewer")
  enrollments                    Enrollment[]
  lessonProgress                 LessonProgress[]
  lessonQuestions                LessonQuestion[]
  lessonQuestionLikes            LessonQuestionLike[]
  lessonQuestionReplies          LessonQuestionReply[]
  sessionBookings                MentorAvailabilitySlot[]  @relation("SessionBookings")
  sessionSlotsCreated            MentorAvailabilitySlot[]  @relation("SessionSlotsCreated")
  mentorProfile                  MentorProfile?
  notes                          Note[]
  passwordResetTokens            PasswordResetToken[]
  emailVerificationTokens        EmailVerificationToken[]
  playlists                      Playlist[]
  reviews                        Review[]
  transactions                   Transaction[]
  watchlistItems                 WatchlistItem[]
  learningGuidanceProfile        LearningGuidanceProfile?
  activeSessions                 UserSession[]
  refreshTokens                  RefreshToken[]
  courseDisputes                 CourseDispute[]
  pollVotes                      PollVote[]
}

/// Active device/session anchors for lifetime-access excludability — concurrent
/// session cap, per-user watermark identity, and anomaly detection (QC-20260719-38).
/// This is NOT a change to price/lifetime (LOCKED); it only limits credential sharing.
model UserSession {
  id         String          @id @default(cuid())
  userId     String
  /// Hashed device fingerprint (never raw). Stable per browser/app install.
  deviceHash String
  ipHash     String?
  userAgent  String?
  platform   ClientPlatform  @default(WEB)
  pushToken  String?
  createdAt  DateTime        @default(now())
  lastSeenAt DateTime        @default(now())
  revokedAt  DateTime?
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([userId, deviceHash])
  @@index([userId, revokedAt])
  @@index([userId, lastSeenAt])
}

/// Opaque refresh tokens for native mobile clients (hashed at rest).
model RefreshToken {
  id            String          @id @default(cuid())
  userId        String
  userSessionId String?
  tokenHash     String          @unique
  deviceHash    String
  platform      ClientPlatform  @default(IOS)
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userSession   UserSession?    @relation(fields: [userSessionId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

/// Quiz answers from the learning-path onboarding ("jembatannya").
model LearningGuidanceProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  instrument       Instrument
  experienceLevel  CourseLevel
  /// Preserves never vs demo nuance (both map to PEMULA experienceLevel).
  experienceTier   LearningExperience       @default(DEMO)
  tradingStyle     LearningTradingStyle
  goal             LearningGoal
  riskTolerance    LearningRiskTolerance
  timeAvailability LearningTimeAvailability
  capitalRange     LearningCapitalRange?
  learningFormat   LearningFormat
  completedAt      DateTime                 @default(now())
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instrument, experienceLevel])
}

/// Single-use reset token — stores hash only, never plaintext (UU PDP / GDPR-ready).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Single-use email verification token for password-register accounts.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MentorProfile {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  slug               String                   @unique
  title              String
  initials           String
  avatarUrl          String?
  bio                String
  philosophy         String
  spesialisasi       String
  instruments        Json
  licenseLabel       String?
  verificationStatus VerificationStatus       @default(PENDING)
  yearsExperience    Int
  studentsCount      Int                      @default(0)
  coursesCount       Int                      @default(0)
  rating             Float                    @default(0)
  trackRecord        Json
  availableFor1on1   Boolean                  @default(false)
  /// Legacy free-form display string. Deprecated — use sessionPriceInt for logic (QC-20260719-22).
  sessionPrice       String?
  /// Validated numeric 1-on-1 session price (Rupiah). Source of truth for commitment fee & ledger.
  sessionPriceInt    Int?
  /// Distinct COMPLETED paid buyers across this mentor's courses — the only student
  /// metric allowed to drive ranking/discovery (QC-20260719-26/27). Derived, never self-set.
  paidStudentsCount  Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  socialLinks        Json?
  tagline            String?
  chatRooms          ChatRoom[]
  commissionRecords  CommissionRecord[]
  courses            Course[]
  availabilitySlots  MentorAvailabilitySlot[]
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingSignals     TradingSignal[]
  /// Session-payment ledger rows (kind=SESSION) attributed to this mentor (QC-20260719-22/47).
  sessionTransactions Transaction[]

  @@index([verificationStatus, studentsCount])
}

/// Admin-managed time slots for mentor 1-on-1 sessions.
model MentorAvailabilitySlot {
  id               String                  @id @default(cuid())
  mentorId         String
  startAt          DateTime
  endAt            DateTime
  isBooked         Boolean                 @default(false)
  bookedByUserId   String?
  createdByAdminId String?
  notes            String?
  /// Booking lifecycle for no-show/cancel accountability (QC-20260719-21).
  bookedAt         DateTime?
  cancelledAt      DateTime?
  /// One-time commitment fee (Rupiah) captured at booking; forfeited on no-show. Not recurring (LOCKED).
  commitmentFee    Int                     @default(0)
  attendanceStatus SessionAttendanceStatus @default(SCHEDULED)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  bookedBy         User?                   @relation("SessionBookings", fields: [bookedByUserId], references: [id])
  createdByAdmin   User?                   @relation("SessionSlotsCreated", fields: [createdByAdminId], references: [id])
  mentor           MentorProfile           @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  /// On-platform session-payment ledger rows for this booking (QC-20260719-22/47).
  transactions     Transaction[]

  @@index([mentorId, startAt])
  @@index([mentorId, isBooked, startAt])
  @@index([bookedByUserId, isBooked])
}

model Course {
  id                String                @id @default(cuid())
  slug              String                @unique
  title             String
  mentorId          String
  instrument        Instrument
  level             CourseLevel
  price             Int
  rating            Float                 @default(0)
  /// Number of reviews behind `rating` — shown to users and used for min-sample downweight (QC-20260719-17).
  ratingCount       Int                   @default(0)
  /// Bayesian-shrunk rating (prior = platform mean) used for ranking to resist low-n gaming (QC-20260719-17).
  bayesianRating    Float                 @default(0)
  /// Time-weighted rating with recency decay — surfaces stale 5★ content (QC-20260719-18/01).
  decayedRating     Float                 @default(0)
  /// When rating aggregates were last recomputed — powers "terakhir diperbarui" staleness badge.
  ratingUpdatedAt   DateTime?
  studentsCount     Int                   @default(0)
  /// Distinct COMPLETED paid buyers — the only popularity signal allowed in ranking (QC-20260719-27).
  paidStudentsCount Int                   @default(0)
  durationHours     Int
  shortDescription  String
  outcomes          Json
  isPublished       Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  /// Last time course content was materially updated — staleness penalty input (QC-20260719-18).
  contentUpdatedAt  DateTime?
  thumbnailUrl      String?
  mentor            MentorProfile         @relation(fields: [mentorId], references: [id])
  changeRequests    CourseChangeRequest[]
  disputes          CourseDispute[]
  enrollments       Enrollment[]
  modules           Module[]
  playlistItems     PlaylistItem[]
  reviews           Review[]
  transactions      Transaction[]

  @@index([isPublished, studentsCount])
  @@index([isPublished, paidStudentsCount])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id              String           @id @default(cuid())
  moduleId        String
  legacyId        String?
  title           String
  description     String?
  durationMinutes Int
  isPreviewGratis Boolean          @default(false)
  videoUrl        String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress  LessonProgress[]
  questions       LessonQuestion[]
  notes           Note[]
  playlistItems   PlaylistItem[]
}

model LessonQuestion {
  id               String                @id @default(cuid())
  lessonId         String
  userId           String
  content          String
  timestampSeconds Int?
  isPinned         Boolean               @default(false)
  likeCount        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  lesson           Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes            LessonQuestionLike[]
  replies          LessonQuestionReply[]
}

model LessonQuestionReply {
  id         String         @id @default(cuid())
  questionId String
  userId     String
  content    String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  question   LessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonQuestionLike {
  id         String         @id @default(cuid())
  questionId String
  userId     String
  createdAt  DateTime       @default(now())
  question   LessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  /// True only when backed by a COMPLETED paid Transaction — separates paid buyers
  /// from free/auto-provisioned enrollments for ranking & eligibility (QC-20260719-26/27).
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([courseId, isPaid])
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  /// Client-reported resume position — display only, NOT trusted for completion (QC-20260719-46).
  watchedSeconds Int      @default(0)
  /// Server-accumulated verified watch time via signed playback heartbeats. Sole gate for
  /// `completed=true` — client cannot inflate it (QC-20260719-16/46).
  verifiedWatchedSeconds Int      @default(0)
  /// Last heartbeat wall-clock timestamp — bounds per-ping credit against replay/seek cheating.
  lastHeartbeatAt        DateTime?
  /// Last verified playhead position (seconds) — advancement is credited, seeks/rewinds are not.
  heartbeatPosition      Int      @default(0)
  updatedAt      DateTime @updatedAt
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  /// Course purchase link. NULL for 1-on-1 session payments (QC-20260719-22/47).
  courseId         String?
  /// 1-on-1 session booking link. NULL for course purchases (QC-20260719-22/47).
  mentorSessionId  String?
  /// Denormalized mentor for SESSION payments (course payments derive mentor via course).
  mentorId         String?
  amount           Int
  /// Discriminates course purchases from 1-on-1 session payments so a single ledger
  /// (Transaction + CommissionRecord 25%) can span both revenue lines (QC-20260719-22/47).
  kind             TransactionKind   @default(COURSE)
  status           TransactionStatus @default(PENDING)
  /// Idempotency guard against duplicate COMPLETED transactions per (user,course/session) or retry (QC-20260719-30).
  idempotencyKey   String?           @unique
  createdAt        DateTime          @default(now())
  commissionRecord CommissionRecord?
  course           Course?                 @relation(fields: [courseId], references: [id])
  mentorSession    MentorAvailabilitySlot? @relation(fields: [mentorSessionId], references: [id])
  mentor           MentorProfile?          @relation(fields: [mentorId], references: [id])
  user             User                    @relation(fields: [userId], references: [id])

  @@index([courseId, createdAt])
  @@index([status])
  @@index([userId, courseId, status])
  @@index([mentorSessionId])
  @@index([mentorId, kind])
}

model Review {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  rating           Int
  comment          String
  /// True only if the reviewer has a COMPLETED paid Transaction for the course (QC-20260719-15).
  verifiedPurchase Boolean  @default(false)
  /// Set by reciprocal-ring / mentor-affiliation detection; flagged reviews are excluded
  /// from public aggregates and queued for moderation (QC-20260719-34).
  isFlagged        Boolean  @default(false)
  flagReason       String?
  createdAt        DateTime @default(now())
  course           Course   @relation(fields: [courseId], references: [id])
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([courseId, createdAt])
}

model Note {
  id               String   @id @default(cuid())
  userId           String
  lessonId         String
  content          String
  /// Video playhead (seconds) when the note was created / linked.
  timestampSeconds Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([lessonId, timestampSeconds])
}

model WatchlistItem {
  id         String     @id @default(cuid())
  userId     String
  ticker     String
  instrument Instrument
  notes      String?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

/// Platform-curated lesson collections (admin-managed). User-created playlists are disabled.
model Playlist {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?
  slug        String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isCurated   Boolean        @default(false)
  isPublished Boolean        @default(false)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PlaylistItem[]

  @@index([isCurated, isPublished, createdAt])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  /// Lesson reference when the item is a specific video/module segment.
  lessonId   String?
  /// Course reference when the item points at a whole class (optional).
  courseId   String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson     Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, sortOrder])
}

model ChatRoom {
  id                   String                    @id @default(cuid())
  /// Null for PUBLIC platform rooms; required for mentor-owned rooms.
  mentorId             String?
  name                 String
  slug                 String
  description          String?
  roomKind             ChatRoomKind              @default(MENTOR_COMMUNITY)
  tier                 ChatRoomTier              @default(PEMULA)
  isProtected          Boolean                   @default(false)
  screenshotProtection Boolean                   @default(false)
  memberOnly           Boolean                   @default(true)
  /// Shared staff room (e.g. mentor–admin kolaborasi) — does not count toward mentor ownership limits.
  isStaffCollaboration Boolean                   @default(false)
  isActive             Boolean                   @default(true)
  isLive               Boolean                   @default(false)
  liveStartedAt        DateTime?
  liveTitle            String?
  createdAt            DateTime                  @default(now())
  auditLogs            ChatAuditLog[]
  branches             ChatBranch[]
  branchChangeRequests ChatBranchChangeRequest[]
  messages             ChatMessage[]
  mentor               MentorProfile?            @relation(fields: [mentorId], references: [id])
  members              ChatRoomMember[]
  tradingPolls         TradingPoll[]
  tradingSignals       TradingSignal[]

  @@unique([mentorId, slug])
  @@index([roomKind, isActive])
}

/// Channel / cabang under a mentor hub. Visibility (public/private) is per-branch.
model ChatBranch {
  id             String                    @id @default(cuid())
  roomId         String
  name           String
  slug           String
  description    String?
  mode           ChatBranchMode            @default(TWO_WAY)
  senderPolicy   ChatBranchSenderPolicy    @default(MENTOR_ONLY)
  /// PUBLIC = members can access; PRIVATE = mentor/moderator only (developers blocked).
  visibility     ChatBranchVisibility      @default(PUBLIC)
  sortOrder      Int                       @default(0)
  isActive       Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  room           ChatRoom                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  changeRequests ChatBranchChangeRequest[]
  messages       ChatMessage[]

  @@unique([roomId, slug])
  @@index([roomId, sortOrder])
}

model ChatRoomMember {
  id         String         @id @default(cuid())
  roomId     String
  userId     String
  role       ChatMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())
  lastReadAt DateTime?
  room       ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model ChatMessage {
  id          String                @id @default(cuid())
  roomId      String
  /// Set for mentor hub branches; null for PUBLIC rooms (room-level thread).
  branchId    String?
  userId      String
  content     String
  messageType MessageType           @default(TEXT)
  metadata    Json?
  isPinned    Boolean               @default(false)
  replyToId   String?
  createdAt   DateTime              @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?
  branch      ChatBranch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  replyTo     ChatMessage?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     ChatMessage[]         @relation("MessageReplies")
  room        ChatRoom              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id])
  reactions   ChatMessageReaction[]

  @@index([roomId, branchId, createdAt])
}

model ChatMessageReaction {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ChatAuditLog {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model TradingSignal {
  id                String          @id @default(cuid())
  roomId            String
  mentorId          String
  ticker            String
  instrument        Instrument
  direction         SignalDirection
  entryPrice        Float
  targetPrice       Float?
  stopLoss          Float?
  rationale         String?
  status            SignalStatus    @default(ACTIVE)
  /// Optional forced-resolution deadline; expiry auto-resolves the signal (QC-20260719-19).
  expiresAt         DateTime?
  /// Platform-computed outcome — mentors cannot delete losing signals (QC-20260719-19).
  outcome           SignalOutcome   @default(PENDING)
  /// Platform-computed realized return vs entryPrice at resolution (percent).
  realizedReturnPct Float?
  resolvedAt        DateTime?
  createdAt         DateTime        @default(now())
  closedAt          DateTime?
  mentor            MentorProfile   @relation(fields: [mentorId], references: [id])
  room              ChatRoom        @relation(fields: [roomId], references: [id])

  @@index([mentorId, outcome])
  @@index([status, expiresAt])
}

model TradingPoll {
  id        String     @id @default(cuid())
  roomId    String
  question  String
  /// Option definitions only (id + label + cached count). Voter identities live in
  /// PollVote, never returned to viewers (QC-20260719-23) and bounded in size (QC-20260719-41).
  options   Json
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  room      ChatRoom   @relation(fields: [roomId], references: [id])
  votes     PollVote[]
}

/// Normalized poll vote — one row per (poll,user). Keeps voter identity server-side
/// (ballot secrecy, QC-20260719-23) and bounds JSON growth (QC-20260719-41).
model PollVote {
  id        String      @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime    @default(now())
  poll      TradingPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, optionId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])
}

model ContentModerationQueue {
  id             String                @id @default(cuid())
  contentType    String
  contentId      String
  reportedBy     String?
  reason         String
  status         ModerationStatus      @default(PENDING)
  /// Snapshot of reporter reputation weight at report time (QC-20260719-40).
  reporterWeight Float                 @default(1)
  /// Outcome vs the reporter — drives reporter reputation (QC-20260719-40).
  resolution     ModerationResolution?
  reviewedBy     String?
  createdAt      DateTime              @default(now())
  reviewedAt     DateTime?
  reporter       User?                 @relation("ReportedBy", fields: [reportedBy], references: [id])
  reviewer       User?                 @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@index([status, createdAt])
}

/// Mentor proposes structural branch changes (add/rename/mode/remove). Admin approves.
model ChatBranchChangeRequest {
  id              String              @id @default(cuid())
  roomId          String
  mentorUserId    String
  /// Existing branch for UPDATE/DELETE; null for CREATE
  branchId        String?
  action          ChangeRequestAction
  summary         String
  currentSnapshot Json?
  proposedData    Json?
  appliedData     Json?
  status          ChangeRequestStatus @default(PENDING)
  adminNote       String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  branch          ChatBranch?         @relation(fields: [branchId], references: [id])
  mentorUser      User                @relation("ChatBranchChangeMentor", fields: [mentorUserId], references: [id])
  reviewer        User?               @relation("ChatBranchChangeReviewer", fields: [reviewedById], references: [id])
  room            ChatRoom            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([roomId])
  @@index([mentorUserId])
}

/// Mentor-submitted proposal to change course content. Only admin can approve & apply.
model CourseChangeRequest {
  id              String                  @id @default(cuid())
  courseId        String
  mentorUserId    String
  targetType      ChangeRequestTargetType
  action          ChangeRequestAction
  /// Existing module id (for MODULE/LESSON updates/deletes, or parent for CREATE LESSON)
  moduleId        String?
  /// Existing lesson id (for LESSON updates/deletes)
  lessonId        String?
  /// Human-readable summary from mentor
  summary         String
  /// Snapshot of current values at submit time
  currentSnapshot Json?
  /// Proposed field values (CREATE/UPDATE payload)
  proposedData    Json?
  /// Final payload applied (may differ if admin edited before approve)
  appliedData     Json?
  status          ChangeRequestStatus     @default(PENDING)
  adminNote       String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  course          Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mentorUser      User                    @relation("ChangeRequestMentor", fields: [mentorUserId], references: [id])
  reviewer        User?                   @relation("ChangeRequestReviewer", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([courseId])
  @@index([mentorUserId])
}

model PlatformConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum KnowledgeChunkSensitivity {
  PUBLIC
  INTERNAL
}

/// RAG knowledge chunks indexed from vault docs (scripts/index-docs.ts).
model KnowledgeChunk {
  id          String                    @id @default(cuid())
  sourceDoc   String
  heading     String
  content     String
  sensitivity KnowledgeChunkSensitivity @default(PUBLIC)
  allowedRoles  String[]                  @default([])
  embedding   Unsupported("vector")?
  tokenCount  Int                       @default(0)
  updatedAt   DateTime                  @updatedAt
  createdAt   DateTime                  @default(now())

  @@index([sourceDoc])
  @@index([sensitivity])
}

model AiConversation {
  id         String      @id @default(cuid())
  userId     String
  feature    AiFeature   @default(SUPPORT_BOT)
  summary    String?
  lastTurnAt DateTime    @default(now())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   AiMessage[]

  @@index([userId, lastTurnAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String
  tokenCount     Int            @default(0)
  model          String?
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AiUsageLog {
  id           String    @id @default(cuid())
  userId       String?
  feature      AiFeature
  model        String
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  costEstimate Float     @default(0)
  cacheHit     Boolean   @default(false)
  latencyMs    Int?
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id])

  @@index([feature, createdAt])
  @@index([userId, createdAt])
}

model CommissionRecord {
  id               String        @id @default(cuid())
  transactionId    String        @unique
  mentorId         String
  grossAmount      Int
  commissionPct    Float         @default(25)
  commissionAmount Int
  netMentorAmount  Int
  payoutStatus     PayoutStatus  @default(PENDING)
  payoutPeriod     String?
  /// Published payout SLA target (period cut-off + T+X). Enables ETA & hold-up audit (QC-20260719-14).
  payoutDueAt      DateTime?
  /// Timestamp when payout actually reached PAID — for SLA reconciliation (QC-20260719-14).
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  mentor           MentorProfile @relation(fields: [mentorId], references: [id])
  transaction      Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([mentorId, createdAt])
  @@index([payoutStatus, payoutPeriod])
  @@index([payoutStatus, payoutDueAt])
}

